# 服务端口
PORT=8080

# MySQL（先执行项目根目录 sql/schema.sql 建库建表）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=yujixinjiang

# JWT 密钥（随便填一串长字符，生产环境务必更换）
JWT_SECRET=change-me-to-a-long-random-string

# 微信小程序（后续登录接口会用到，现在可以先留空）
WECHAT_APPID=
WECHAT_SECRET=

# 支付渠道：mock=模拟支付（默认，下单即记已付）；wechat=微信支付（需启用并配置商户）
PAYMENT_PROVIDER=mock
WECHAT_PAY_ENABLED=false
WECHAT_MCH_ID=
WECHAT_PAY_API_KEY=
WECHAT_PAY_NOTIFY_URL=

# 数据库定时备份（需本机安装 mysqldump / mysql-client）
BACKUP_ENABLED=false
BACKUP_DIR=backups
BACKUP_INTERVAL=24h
BACKUP_RETAIN_DAYS=7
UPLOAD_DIR=uploads
UPLOAD_URL_PREFIX=/uploads
UPLOAD_PUBLIC_BASE=https://weixin.catmicloud.cn
AVATAR_PUBLIC_BASE=https://weixin.catmicloud.cn
UPLOAD_MAX_MB=10
